<mxfile host="app.diagrams.net" modified="2026-07-18T00:00:00.000Z" agent="Claude" version="24.0.0" type="device">
  <diagram name="Valid Palindrome - Two Pointer" id="valid-palindrome-two-pointer">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Start -->
        <mxCell id="start" value="Start" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="440" y="40" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Init pointers -->
        <mxCell id="init" value="left = 0&#10;right = len(s) - 1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="420" y="130" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- Main loop condition -->
        <mxCell id="loopCond" value="left &lt; right ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="440" y="220" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- True: return True -->
        <mxCell id="returnTrue" value="return True" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="760" y="235" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Skip non-alphanumeric on left -->
        <mxCell id="skipLeft" value="while left &lt; right and&#10;s[left] not alphanumeric:&#10;  left += 1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="400" y="350" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Skip non-alphanumeric on right -->
        <mxCell id="skipRight" value="while left &lt; right and&#10;s[right] not alphanumeric:&#10;  right -= 1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="400" y="450" width="240" height="60" as="geometry" />
        </mxCell>

        <!-- Compare characters -->
        <mxCell id="compare" value="lower(s[left]) ==&#10;lower(s[right]) ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="420" y="550" width="200" height="90" as="geometry" />
        </mxCell>

        <!-- False: return False -->
        <mxCell id="returnFalse" value="return False" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="760" y="565" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Move pointers -->
        <mxCell id="movePointers" value="left += 1&#10;right -= 1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="440" y="680" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="start" target="init">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="init" target="loopCond">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="loopCond" target="returnTrue">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="loopCond" target="skipLeft">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="skipLeft" target="skipRight">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="skipRight" target="compare">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="compare" target="returnFalse">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="compare" target="movePointers">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="movePointers" target="loopCond">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="330" y="705" />
              <mxPoint x="330" y="260" />
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
